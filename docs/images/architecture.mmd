flowchart LR
    %% ---------- Consumers (left) ----------
    subgraph Consumers["Consumers"]
        direction TB
        MCP["MCP clients<br/><i>Claude Desktop / Code</i>"]
        DASH["Dashboard<br/><i>React SPA</i>"]
        REST["Your app<br/><i>via REST API</i>"]
        CHAT["Local LLM chat<br/><i>LM Studio / Ollama</i>"]
    end

    %% ---------- Memory Vault core (middle) ----------
    subgraph MV["Memory Vault &nbsp;&nbsp; (single Docker container)"]
        direction TB
        API["FastAPI<br/>+ MCP server<br/>+ bearer auth"]
        SEARCH["Hybrid search<br/><i>vector · tsvector · RRF</i>"]
        GRAPH["Knowledge graph<br/><i>spaCy NER + relationships</i>"]
        INGEST["Ingestion<br/><i>markdown · plaintext · Claude JSON</i>"]
    end

    %% ---------- Storage (right) ----------
    subgraph Storage["Storage"]
        direction TB
        PG[("Postgres 16<br/>+ pgvector<br/><i>HNSW + GIN indexes</i>")]
    end

    %% ---------- Edges ----------
    MCP  -->|"recall · remember<br/>forget · status"| API
    DASH -->|"REST + bearer"| API
    REST -->|"REST + bearer"| API
    CHAT -->|"RAG + SSE"| API

    API --> SEARCH
    API --> GRAPH
    API --> INGEST

    SEARCH --> PG
    GRAPH  --> PG
    INGEST --> PG

