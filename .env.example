# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=memory_vault
DB_USER=memory_vault
DB_PASSWORD=memory_vault

# API
API_HOST=0.0.0.0
API_PORT=8000

# API auth — bearer-token authentication is enabled by default. Generate
# tokens via `memory-vault token create <name>` (the plaintext is shown
# once). Set API_AUTH_ENABLED=false ONLY for local development with a
# trusted network — never expose an unauthenticated instance to the
# public internet.
API_AUTH_ENABLED=true

# Sliding-window rate limit per client IP, per minute. Applies to all
# endpoints except /api/health, /docs, /redoc, /openapi.json.
API_RATE_LIMIT_PER_MIN=120

# CORS origins — comma-separated list of allowed origins for browser
# clients, or "*" for any. The default "*" is intended for local-dev
# only; in production set this to your dashboard's exact origin.
API_CORS_ORIGINS=*

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
EMBEDDING_BATCH_SIZE=32

# Search
RRF_K=60
SEARCH_DEFAULT_LIMIT=10
